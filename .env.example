# Neon Postgres
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/stackpulse?sslmode=require

# BetterAuth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth (optional — enables "Continue with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub API token (optional — raises rate limit from 60/h to 5000/h)
GITHUB_TOKEN=

# OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Better Auth Dash (optional — enables dashboard at dash.better-auth.com)
BETTER_AUTH_API_KEY=

# Cron Security
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Weekly digest emails (optional — digest cron no-ops without both)
# RESEND_API_KEY from https://resend.com, DIGEST_FROM_EMAIL must be a verified sender
RESEND_API_KEY=
DIGEST_FROM_EMAIL="StackPulse <digest@yourdomain.com>"

# Error monitoring (optional — Sentry stays fully disabled without a DSN)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for source map upload in CI: SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

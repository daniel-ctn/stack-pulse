# Neon Postgres
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/stackpulse?sslmode=require

# BetterAuth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth (optional — enables "Continue with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub API token (optional — raises rate limit from 60/h to 5000/h)
GITHUB_TOKEN=

# OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Better Auth Dash (optional — enables dashboard at dash.better-auth.com)
BETTER_AUTH_API_KEY=

# Cron Security
# Generate with: openssl rand -hex 32
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

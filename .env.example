# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Cron Security
CRON_SECRET=your-cron-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
